{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=graphql_bookstore;Username=postgres;Password=postgres"
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "Jwt": {
    "Issuer": "graphql-bookstore-api",
    "Audience": "graphql-bookstore-clients",
    "SigningKey": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARACTERS",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Identity": {
    "SeedDefaults": true,
    "DefaultAdmin": {
      "Email": "admin@example.com",
      "Password": "Admin123!"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
