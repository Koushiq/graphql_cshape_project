{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=graphql_bookstore;Username=postgres;Password=admin1234"
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "Jwt": {
    "Issuer": "graphql-bookstore-api",
    "Audience": "graphql-bookstore-clients",
    "SigningKey": "dev-only-super-secret-key-change-before-production",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Identity": {
    "SeedDefaults": true,
    "DefaultAdmin": {
      "Email": "admin@example.com",
      "Password": "Admin123!"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
